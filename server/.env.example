# Server Environment Variables
# Copy this file to .env and fill in your values.

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=<appName>

# JWT secret — use a long, random string in production (e.g. openssl rand -base64 64)
JWT_SECRET=replace_with_a_long_random_secret

# Allowed frontend origin (used for CORS in production)
CLIENT_URL=http://localhost:5173
